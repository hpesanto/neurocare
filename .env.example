# Copie para .env e ajuste os valores.  O .env NÃO vai para o git.
# O docker-compose.yml lê estas variáveis (com fallback para os valores de dev).

# === Django ===
NEUROCARE_SECRET_KEY=your-secret-key-here-change-in-production
# Em produção use: false
NEUROCARE_DEBUG=true
# Em produção INCLUA o IP/domínio pelo qual o sistema é acessado, ex.:
#   NEUROCARE_ALLOWED_HOSTS=187.127.37.57,meudominio.com,localhost,127.0.0.1,backend
NEUROCARE_ALLOWED_HOSTS=127.0.0.1,localhost,backend

# === Postgres (também usado pelo docker-compose) ===
# ATENÇÃO: estes valores só são aplicados na PRIMEIRA criação do volume.
# Se mudar depois, o banco mantém as credenciais antigas (precisa recriar o volume).
# Dentro do docker, POSTGRES_HOST deve ser "postgres" (nome do serviço).
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === CORS ===
# Em produção inclua a origem usada no navegador, ex.:
#   CORS_ALLOWED_ORIGINS=http://187.127.37.57:3000,http://meudominio.com,https://meudominio.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
